{
  "name": "@capsuleui/core",
  "version": "1.2.7",
  "description": "CapsuleUI: Native Web Components, unstyled by design. Build your own design system on a solid foundation. Like shadcn, for the web platform.",
  "author": "ZiZIGY",
  "license": "MIT",
  "type": "module",
  "bin": "./dist/cli.js",
  "keywords": [
    "web-components",
    "custom-elements",
    "ui-components",
    "design-system",
    "component-library",
    "unstyled",
    "shadcn",
    "lit-element",
    "frontend",
    "ui-library",
    "capsuleui",
    "components",
    "ui",
    "css-components",
    "form-components",
    "button",
    "input",
    "textarea",
    "radio",
    "checkbox",
    "select",
    "dropdown",
    "modal",
    "dialog",
    "tooltip",
    "accordion",
    "tabs",
    "pagination",
    "calendar",
    "datepicker",
    "slider",
    "range",
    "progress",
    "badge",
    "alert",
    "notification",
    "breadcrumb",
    "stepper",
    "rating",
    "accessibility",
    "a11y",
    "wcag",
    "typescript",
    "vanilla-js",
    "framework-agnostic",
    "headless",
    "copy-to-clipboard",
    "cli-tool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZiZIGY/CapsuleUI.git"
  },
  "scripts": {
    "start": "vite build --watch",
    "play": "vite serve playground",
    "build": "tsup",
    "dev:cli": "tsup --watch",
    "dev:play": "vite serve playground",
    "dev": "npm-run-all --parallel dev:cli dev:play",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "prepublishOnly": "npm run build",
    "capsule": "node ./dist/cli.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "dist",
    "src/",
    "templates",
    "src/templates"
  ],
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^18.11.18",
    "@vitejs/plugin-vue": "^4.2.3",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.38.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "rimraf": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.0",
    "typescript": "^4.9.5",
    "vite": "^4.3.9",
    "vite-plugin-dts": "^4.5.0",
    "vitepress": "^1.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
